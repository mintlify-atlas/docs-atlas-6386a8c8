  "keyFeatures": [
    "Self-hosted error tracking and monitoring",
    "Airbrake API compatible for easy integration",
    "Error grouping and fingerprinting",
    "Issue tracker integration (GitHub, Bitbucket, JIRA)",
    "Multiple notification services (Slack, Email, Webhook, Campfire)",
    "OAuth authentication (GitHub, Google, LDAP)",
    "Multi-app and multi-environment support",
    "Error statistics and analytics",
    "User and watcher management",
    "Docker and Kubernetes deployment ready"
  ],
  "publicApiSurface": [
    "POST /notifier_api/v2/notices - Create error notice (Airbrake compatible)",
    "POST /api/v3/projects/:project_id/notices - Create error notice (v3)",
    "GET /api/v1/problems - List problems",
    "GET /api/v1/problems/:id - Get problem details",
    "GET /api/v1/notices - List notices",
    "POST /api/v1/problems/:problem_id/comments - Create comment",
    "GET /api/v1/problems/:problem_id/comments - List comments",
    "GET /api/v1/stats/app - Get app statistics",
    "GET /locate/:id - Locate notice by ID",
    "POST /apps/:app_id/problems/:id/resolve - Resolve problem",
    "POST /apps/:app_id/problems/:id/create_issue - Create issue in tracker"
  ]
